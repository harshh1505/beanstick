{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["zerog/**/*", "protocol/**/*", "agents/**/*", "keepers/**/*", "scripts/**/*", "services/**/*"],
  "exclude": ["node_modules", "dist", "apps", "services/axl-node", "contracts"]
}
