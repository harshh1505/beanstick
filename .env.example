# ==========================================
# Beanstick Environment Variables Example
# ==========================================

# ------------------------------------------
# Blockchain / Network
# ------------------------------------------
# RPC URLs for network interaction
ZEROG_TESTNET_RPC="https://evmrpc-testnet.0g.ai"

# ------------------------------------------
# Cryptography & Keys
# ------------------------------------------
# Deployer/Agent private key (without 0x prefix)
PRIVATE_KEY="your_private_key_here"

# ------------------------------------------
# Smart Contract Addresses (0G Testnet)
# ------------------------------------------
INFT_CONTRACT_ADDRESS="0x..."
ESCROW_ADDRESS="0x..."
TEST_ERC20_ADDRESS="0x..."

# ------------------------------------------
# Smart Contract Addresses (Base Sepolia)
# ------------------------------------------
ESCROW_ADDRESS_BASESEP="0x..."
TEST_ERC20_ADDRESS_BASESEP="0x..."

# ------------------------------------------
# Agent Server
# ------------------------------------------
AGENT_SERVER_PORT="4002"
AGENT_SERVER_URL="http://127.0.0.1:4002"
BEANSTICK_DATA_DIR="/tmp/beanstick"

# ------------------------------------------
# Webhook & Payments
# ------------------------------------------
WEBHOOK_PORT="4001"
WEBHOOK_RECEIVER_URL="http://127.0.0.1:4001/webhook/payment"
PAYMENT_WEBHOOK_SECRET="your_webhook_secret_here"
WEBHOOK_ORDERS_FILE="/tmp/beanstick-orders.json"

# ------------------------------------------
# API Keys & Third-Party Services
# ------------------------------------------
KH_API_KEY="your_keeperhub_api_key"
WFB_KEY="your_wfb_key"

# ------------------------------------------
# Protocols
# ------------------------------------------
AXL_BRIDGE_URL="http://127.0.0.1:9002"
X402_FACILITATOR_URL="https://facilitator.x402.org"

# ------------------------------------------
# Frontend (Next.js)
# ------------------------------------------
NEXT_PUBLIC_AGENT_SERVER_URL="http://127.0.0.1:4002"

# ------------------------------------------
# Graph Intelligence (AuraDB)
# ------------------------------------------
AURADB_URI="neo4j+s://xxxx.databases.neo4j.io"
AURADB_USERNAME="neo4j"
AURADB_PASSWORD="your_auradb_password_here"
AURADB_DATABASE="neo4j"
